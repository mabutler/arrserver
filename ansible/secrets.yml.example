---
# Copy this file to secrets.yml and fill in real values before running bootstrap.
# secrets.yml is gitignored and should never be committed.

# Tailscale auth key — generate one at https://login.tailscale.com/admin/settings/keys
tailscale_auth_key: "tskey-auth-REPLACE_ME"

# Password for the remote download server — used once to install the SSH key, safe to remove after
sync_remote_password: "REPLACE_ME"
