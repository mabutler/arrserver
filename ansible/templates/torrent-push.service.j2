[Unit]
Description=Push torrent files to remote download server
After=network-online.target

[Service]
Type=oneshot
User={{ server_user }}
ExecStart=rsync -avz --bwlimit={{ sync_bwlimit_kbps }} \
  -e "ssh -i {{ sync_ssh_key_path }} -o StrictHostKeyChecking=yes" \
  /data/torrents/ \
  {{ sync_remote_user }}@{{ sync_remote_host }}:{{ sync_remote_watch_dir }}/
